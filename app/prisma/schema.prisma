generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Resume {
  id           String   @id @default(cuid())
  clerkUserId  String

  fileName     String
  content      String

  atsScore     Int?

  summary      String?

  strengths    Json?

  weaknesses   Json?

  keywords     Json?

  createdAt    DateTime @default(now())
}

model Interview {
  id           String   @id @default(cuid())
  clerkUserId  String
  jobRole      String
  experience   String
  techStack    String
  description  String
  questions    Json
  createdAt    DateTime @default(now())

  answers      InterviewAnswer[]
  evaluation   InterviewEvaluation?
}

model InterviewAnswer {
  id           String   @id @default(cuid())
  interviewId  String
  question     String
  answer       String
  createdAt    DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model InterviewEvaluation {
  id                 String   @id @default(cuid())
  interviewId        String   @unique

  overallScore       Int
  technicalScore     Int
  communicationScore Int
  confidenceScore    Int

  strengths          Json
  improvements       Json
  feedback           String

  createdAt          DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}