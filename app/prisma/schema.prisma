generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  createdAt DateTime @default(now())

  resumes   Resume[]
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  content   String
  atsScore  Int?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}